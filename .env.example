# Deploy wallet private key (testnet only — never use a mainnet key with real funds here)
DEPLOYER_PK=0xyour_testnet_private_key
DEPLOYER_ADDRESS=0xyour_testnet_address

# Optional: Z.AI API key to enable the LLM semantic audit layer (free tier: glm-4.5-flash)
# Without it, the agent runs in deterministic static-only mode.
ZAI_API_KEY=

# Optional: Etherscan V2 API key (one key covers Mantle via chainid 5003) for verified-source fetch
ETHERSCAN_API_KEY=

# Optional overrides
# MANTLE_RPC=https://rpc.sepolia.mantle.xyz
# REGISTRY_ADDRESS=0x...
# PORT=8790
